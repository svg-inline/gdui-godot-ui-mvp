{
  "name": "gdui-godot-ui-mvp-workspace",
  "version": "0.1.3",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "gdui-godot-ui-mvp-workspace",
      "version": "0.1.3",
      "workspaces": [
        "packages/*",
        "tools/gdui"
      ],
      "devDependencies": {},
      "engines": {
        "node": ">=18.0.0"
      }
    },
    "node_modules/@gdui/cli": {
      "resolved": "tools/gdui",
      "link": true
    },
    "node_modules/@gdui/compiler": {
      "resolved": "packages/compiler",
      "link": true
    },
    "node_modules/@gdui/godot-exporter": {
      "resolved": "packages/godot-exporter",
      "link": true
    },
    "node_modules/@gdui/theme-exporter": {
      "resolved": "packages/theme-exporter",
      "link": true
    },
    "packages/compiler": {
      "name": "@gdui/compiler",
      "version": "0.1.0",
      "engines": {
        "node": ">=18.0.0"
      }
    },
    "packages/godot-exporter": {
      "name": "@gdui/godot-exporter",
      "version": "0.1.0",
      "dependencies": {
        "@gdui/compiler": "*"
      },
      "engines": {
        "node": ">=18.0.0"
      }
    },
    "packages/theme-exporter": {
      "name": "@gdui/theme-exporter",
      "version": "0.1.0",
      "dependencies": {
        "@gdui/compiler": "*"
      },
      "engines": {
        "node": ">=18.0.0"
      }
    },
    "tools/gdui": {
      "name": "@gdui/cli",
      "version": "0.1.1",
      "dependencies": {
        "@gdui/compiler": "*",
        "@gdui/godot-exporter": "*",
        "@gdui/theme-exporter": "*"
      },
      "bin": {
        "gdui": "bin/gdui.js"
      },
      "engines": {
        "node": ">=18.0.0"
      }
    }
  }
}
