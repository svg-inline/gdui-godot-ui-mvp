anchor_bottom = 1.0
color = Color(0.007843, 0.023529, 0.090196, 1)
mouse_filter = 2

[node name="Root" type="VBoxContainer" parent="."]
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 32
offset_top = 32
offset_right = -32
offset_bottom = -32
theme_override_constants/separation = 20

[node name="Title" type="Label" parent="Root"]
text = "Formulário de Exemplo"
