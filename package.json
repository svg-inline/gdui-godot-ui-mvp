{
  "name": "gdui-godot-ui-mvp-workspace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "tools/gdui"
  ],
  "scripts": {
    "compile": "node tools/gdui/bin/gdui.js --input ui --output scenes",
    "compile:theme": "node tools/gdui/bin/gdui.js --theme theme.gdui.json --output scenes/theme.tres",
    "studio": "node addons/gdui/server/studio-server.js --root .",
    "test": "node --test tools/gdui/tests/*.test.js",
    "test:godot": "node tools/godot/run-smoke.js tools/godot/smoke_load_scenes.gd tools/godot/test_responsive_runtime.gd tools/godot/test_action_router.gd tools/godot/test_binding_runtime.gd tools/godot/test_studio_controller.gd",
    "build:addon": "node tools/build-addon.js",
    "validate:addon": "node tools/validate-addon-bundle.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
