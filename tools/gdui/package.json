{
  "name": "@gdui/cli",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "bin": {
    "gdui": "bin/gdui.js"
  },
  "scripts": {
    "compile": "node bin/gdui.js --input ../../ui --output ../../scenes",
    "check": "node bin/gdui.js --input ../../ui/inventory.gdui.html --check",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@gdui/compiler": "*",
    "@gdui/godot-exporter": "*",
    "@gdui/theme-exporter": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
