[gd_scene load_steps=2 format=3]

[ext_resource type="Theme" path="res://scenes/theme.tres" id="GduiTheme"]

[node name="FormComponentsScreen" type="Control"]
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 1.0
